{
  "name": "ben-montgomery-theme",
  "version": "0.1.0",
  "private": true,
  "description": "Block theme workflow for the Ben Montgomery site.",
  "scripts": {
    "postinstall": "node ./scripts/patch-wp-env-playground.mjs",
    "wp-env": "wp-env",
    "wp-env:patch": "node ./scripts/patch-wp-env-playground.mjs",
    "playground:start": "npm run wp-env:patch && wp-env start --runtime=playground --update --auto-port",
    "playground:status": "npm run wp-env:patch && wp-env status",
    "playground:stop": "npm run wp-env:patch && wp-env stop",
    "playground:destroy": "npm run wp-env:patch && wp-env destroy",
    "wp:theme:activate": "./bin/wp-local theme activate ben-montgomery",
    "wp:plugin:list": "./bin/wp-local plugin list",
    "wp:seed": "./scripts/seed-content.sh",
    "wp:sync-site-editor": "./scripts/sync-site-editor.sh",
    "lint:php": "php -l functions.php && php -l inc/class-ben-montgomery-site-editor-sync-command.php",
    "lint:theme-json": "node -e \"JSON.parse(require('node:fs').readFileSync('theme.json', 'utf8'))\"",
    "check": "npm run lint:php && npm run lint:theme-json"
  },
  "devDependencies": {
    "@wordpress/env": "^11.3.0"
  }
}
