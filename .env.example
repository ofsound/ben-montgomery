# Copy to .env and fill in real values. .env is gitignored.
# After editing, run: npm run backup:ftp-test  (from this theme folder)
# npm run upload = new backup (wp ai1wm) then FTP upload. npm run upload:ftp = FTP only (newest .wpress).
#
# curl uses the first ":" in --user as the split between login and password.
# If your password contains ":", use a hosting panel to set a different password
# or switch to a tool that supports .netrc.

FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=your_jailed_backup_user
FTP_PASS=replace-with-real-password

# 1 = explicit TLS (FTPES) on the control connection; 0 = plain FTP
FTP_TLS=0

# 1 = passive mode (default). Matches "Passive mode" in GUI clients; required on most NAT/home networks.
# Set to 0 only if your host insists on active (rare).
FTP_PASSIVE=1

# If uploads hang or fail while passive works in FileZilla, try 1 (curl uses classic PASV instead of EPSV).
FTP_DISABLE_EPSV=0

# Chrooted to ai1wm-backups: leave empty — the upload uses the file basename only.
# Otherwise set a relative subpath (no leading slash), e.g. archive
FTP_REMOTE_DIR=
