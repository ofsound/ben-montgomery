{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "base",
          "name": "Base",
          "color": "light-dark(#f4f5f7, #0f1117)"
        },
        {
          "slug": "canvas",
          "name": "Canvas",
          "color": "light-dark(#ffffff, #181b23)"
        },
        {
          "slug": "contrast",
          "name": "Contrast",
          "color": "light-dark(#1a1c23, #edeef1)"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "light-dark(#6b7280, #9ca3af)"
        },
        {
          "slug": "border",
          "name": "Border",
          "color": "light-dark(#d1d5db, #2e3340)"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "light-dark(#6366f1, #818cf8)"
        },
        {
          "slug": "accent-strong",
          "name": "Accent Strong",
          "color": "light-dark(#2563eb, #60a5fa)"
        },
        {
          "slug": "accent-soft",
          "name": "Accent Soft",
          "color": "light-dark(#e0e7ff, #1e2333)"
        }
      ]
    },
    "custom": {
      "color": {
        "background": "light-dark(#f4f5f7, #0f1117)",
        "surface": "light-dark(#ffffff, #181b23)",
        "text": "light-dark(#1a1c23, #edeef1)",
        "muted": "light-dark(#6b7280, #9ca3af)",
        "border": "light-dark(#d1d5db, #2e3340)",
        "accent": "light-dark(#6366f1, #818cf8)",
        "accentStrong": "light-dark(#2563eb, #60a5fa)",
        "accentSoft": "light-dark(#e0e7ff, #1e2333)",
        "buttonBackground": "light-dark(#1a1c23, #edeef1)",
        "buttonText": "light-dark(#f4f5f7, #0f1117)",
        "shadow": "light-dark(rgba(15, 17, 23, 0.12), rgba(0, 0, 0, 0.45))",
        "shadowHover": "light-dark(rgba(15, 17, 23, 0.18), rgba(0, 0, 0, 0.62))"
      },
      "radius": {
        "card": "1.25rem",
        "pill": "999px"
      }
    },
    "layout": {
      "contentSize": "52rem",
      "wideSize": "72rem"
    },
    "spacing": {
      "blockGap": true,
      "defaultSpacingSizes": false,
      "spacingScale": {
        "operator": "*",
        "increment": 1.35,
        "steps": 0
      },
      "spacingSizes": [
        {
          "slug": "20",
          "name": "2XS",
          "size": "0.5rem"
        },
        {
          "slug": "30",
          "name": "XS",
          "size": "0.875rem"
        },
        {
          "slug": "40",
          "name": "S",
          "size": "1.25rem"
        },
        {
          "slug": "50",
          "name": "M",
          "size": "clamp(1.5rem, 1.15rem + 0.9vw, 2.1rem)"
        },
        {
          "slug": "60",
          "name": "L",
          "size": "clamp(2.25rem, 1.65rem + 1.8vw, 3.7rem)"
        },
        {
          "slug": "70",
          "name": "XL",
          "size": "clamp(3rem, 2.15rem + 3vw, 5rem)"
        },
        {
          "slug": "80",
          "name": "2XL",
          "size": "clamp(4rem, 3rem + 4vw, 6.5rem)"
        }
      ],
      "units": [
        "%",
        "px",
        "rem",
        "vw",
        "vh"
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Inter",
          "fontFamily": "\"Inter\", sans-serif"
        },
        {
          "slug": "display",
          "name": "Sora",
          "fontFamily": "\"Sora\", sans-serif"
        },
        {
          "slug": "mono",
          "name": "JetBrains Mono",
          "fontFamily": "\"JetBrains Mono\", monospace"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1rem",
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          }
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.25rem",
          "fluid": {
            "min": "1.125rem",
            "max": "1.5rem"
          }
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "2rem",
          "fluid": {
            "min": "1.75rem",
            "max": "2.6rem"
          }
        },
        {
          "slug": "xx-large",
          "name": "2X Large",
          "size": "2.7rem",
          "fluid": {
            "min": "2.5rem",
            "max": "4.05rem"
          }
        },
        {
          "slug": "display",
          "name": "Display",
          "size": "3.375rem",
          "fluid": {
            "min": "2.61rem",
            "max": "4.86rem"
          }
        }
      ],
      "lineHeight": true,
      "letterSpacing": true
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--custom--color--background)",
      "text": "var(--wp--custom--color--text)"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "var(--wp--custom--radius--pill)"
        },
        "color": {
          "background": "var(--wp--custom--color--button-background)",
          "text": "var(--wp--custom--color--button-text)"
        },
        "spacing": {
          "padding": {
            "top": "0.9rem",
            "right": "1.4rem",
            "bottom": "0.9rem",
            "left": "1.4rem"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "600",
          "letterSpacing": "0.05em",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontWeight": "600",
          "letterSpacing": "-0.035em",
          "lineHeight": "0.98"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--custom--color--accent-strong)"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "spacing": {
      "blockGap": "1.5rem",
      "padding": {
        "left": "var:preset|spacing|40",
        "right": "var:preset|spacing|40"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "400",
      "letterSpacing": "0",
      "lineHeight": "1.7"
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--pill)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "500",
          "letterSpacing": "0.05em",
          "textTransform": "uppercase"
        },
        "spacing": {
          "blockGap": "var:preset|spacing|40"
        }
      },
      "core/post-content": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/post-date": {
        "color": {
          "text": "var(--wp--custom--color--muted)"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        }
      },
      "core/post-featured-image": {
        "border": {
          "radius": "var(--wp--custom--radius--card)"
        }
      },
      "core/post-terms": {
        "color": {
          "text": "var(--wp--custom--color--muted)"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        }
      },
      "core/pullquote": {
        "border": {
          "top": {
            "color": "var(--wp--custom--color--accent)",
            "width": "2px"
          },
          "bottom": {
            "color": "var(--wp--custom--color--accent)",
            "width": "2px"
          }
        },
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontSize": "var:preset|font-size|x-large",
          "lineHeight": "1.2"
        }
      },
      "core/query": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/query-pagination": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "600",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontSize": "1.5rem",
          "letterSpacing": ".01em"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "social-links",
      "title": "Social Links",
      "area": "uncategorized"
    }
  ]
}