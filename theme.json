{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "base",
          "name": "Base",
          "color": "light-dark(#f8f3ea, #111417)"
        },
        {
          "slug": "canvas",
          "name": "Canvas",
          "color": "light-dark(#ffffff, #1a1e22)"
        },
        {
          "slug": "contrast",
          "name": "Contrast",
          "color": "light-dark(#1c1b19, #f4ede2)"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "light-dark(#5d5a52, #b7ab98)"
        },
        {
          "slug": "border",
          "name": "Border",
          "color": "light-dark(#cfc3b0, #4f5861)"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "light-dark(#b85c38, #f28e63)"
        },
        {
          "slug": "accent-strong",
          "name": "Accent Strong",
          "color": "light-dark(#224d66, #8fc8ea)"
        },
        {
          "slug": "accent-soft",
          "name": "Accent Soft",
          "color": "light-dark(#d9ccb7, #2a333b)"
        }
      ]
    },
    "custom": {
      "color": {
        "background": "light-dark(#f8f3ea, #111417)",
        "surface": "light-dark(#ffffff, #1a1e22)",
        "text": "light-dark(#1c1b19, #f4ede2)",
        "muted": "light-dark(#5d5a52, #b7ab98)",
        "border": "light-dark(#cfc3b0, #4f5861)",
        "accent": "light-dark(#b85c38, #f28e63)",
        "accentStrong": "light-dark(#224d66, #8fc8ea)",
        "accentSoft": "light-dark(#d9ccb7, #2a333b)",
        "buttonBackground": "light-dark(#1c1b19, #f4ede2)",
        "buttonText": "light-dark(#f8f3ea, #111417)",
        "shadow": "light-dark(rgba(28, 27, 25, 0.08), rgba(0, 0, 0, 0.4))",
        "shadowHover": "light-dark(rgba(28, 27, 25, 0.12), rgba(0, 0, 0, 0.55))"
      },
      "radius": {
        "card": "1.5rem",
        "pill": "999px"
      }
    },
    "layout": {
      "contentSize": "50rem",
      "wideSize": "78rem"
    },
    "spacing": {
      "blockGap": true,
      "defaultSpacingSizes": false,
      "spacingScale": {
        "operator": "*",
        "increment": 1.35,
        "steps": 0
      },
      "spacingSizes": [
        {
          "slug": "20",
          "name": "2XS",
          "size": "0.5rem"
        },
        {
          "slug": "30",
          "name": "XS",
          "size": "0.875rem"
        },
        {
          "slug": "40",
          "name": "S",
          "size": "1.25rem"
        },
        {
          "slug": "50",
          "name": "M",
          "size": "clamp(1.5rem, 1.1rem + 1vw, 2.25rem)"
        },
        {
          "slug": "60",
          "name": "L",
          "size": "clamp(2.25rem, 1.5rem + 2vw, 4rem)"
        },
        {
          "slug": "70",
          "name": "XL",
          "size": "clamp(3rem, 2rem + 3vw, 5.5rem)"
        },
        {
          "slug": "80",
          "name": "2XL",
          "size": "clamp(4rem, 3rem + 4vw, 7rem)"
        }
      ],
      "units": [
        "%",
        "px",
        "rem",
        "vw",
        "vh"
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Editorial Sans",
          "fontFamily": "\"Avenir Next\", \"Segoe UI\", sans-serif"
        },
        {
          "slug": "display",
          "name": "Display Serif",
          "fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", serif"
        },
        {
          "slug": "mono",
          "name": "Mono",
          "fontFamily": "\"SFMono-Regular\", Consolas, monospace"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1rem",
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          }
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.25rem",
          "fluid": {
            "min": "1.125rem",
            "max": "1.5rem"
          }
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "2rem",
          "fluid": {
            "min": "1.75rem",
            "max": "2.6rem"
          }
        },
        {
          "slug": "xx-large",
          "name": "2X Large",
          "size": "3rem",
          "fluid": {
            "min": "2.5rem",
            "max": "4.5rem"
          }
        },
        {
          "slug": "display",
          "name": "Display",
          "size": "4rem",
          "fluid": {
            "min": "3rem",
            "max": "6rem"
          }
        }
      ],
      "lineHeight": true,
      "letterSpacing": true
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--custom--color--background)",
      "text": "var(--wp--custom--color--text)"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "var(--wp--custom--radius--pill)"
        },
        "color": {
          "background": "var(--wp--custom--color--button-background)",
          "text": "var(--wp--custom--color--button-text)"
        },
        "spacing": {
          "padding": {
            "top": "0.9rem",
            "right": "1.4rem",
            "bottom": "0.9rem",
            "left": "1.4rem"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "600",
          "letterSpacing": "0.04em",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontWeight": "500",
          "letterSpacing": "-0.03em",
          "lineHeight": "1.05"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--custom--color--accent-strong)"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "spacing": {
      "blockGap": "1.2rem",
      "padding": {
        "left": "var:preset|spacing|50",
        "right": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "400",
      "letterSpacing": "-0.01em",
      "lineHeight": "1.65"
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--pill)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "600",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        },
        "spacing": {
          "blockGap": "var:preset|spacing|40"
        }
      },
      "core/post-content": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/post-date": {
        "color": {
          "text": "var(--wp--custom--color--muted)"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "letterSpacing": "0.04em",
          "textTransform": "uppercase"
        }
      },
      "core/post-featured-image": {
        "border": {
          "radius": "var(--wp--custom--radius--card)"
        }
      },
      "core/post-terms": {
        "color": {
          "text": "var(--wp--custom--color--muted)"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "letterSpacing": "0.04em",
          "textTransform": "uppercase"
        }
      },
      "core/pullquote": {
        "border": {
          "top": {
            "color": "var(--wp--custom--color--accent)",
            "width": "2px"
          },
          "bottom": {
            "color": "var(--wp--custom--color--accent)",
            "width": "2px"
          }
        },
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontSize": "var:preset|font-size|x-large",
          "lineHeight": "1.2"
        }
      },
      "core/query": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/query-pagination": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "600",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontSize": "1.5rem",
          "letterSpacing": "-0.04em"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "social-links",
      "title": "Social Links",
      "area": "uncategorized"
    }
  ]
}
