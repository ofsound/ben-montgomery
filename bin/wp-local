#!/bin/zsh
set -eu

THEME_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
SITE_ROOT=$(CDPATH= cd -- "$THEME_DIR/../../.." && pwd)
SITE_BASE=$(CDPATH= cd -- "$THEME_DIR/../../../../.." && pwd)
LOCAL_HOME=${LOCAL_HOME:-"$HOME/Library/Application Support/Local"}
WP_CLI_SCRIPT=${WP_CLI_SCRIPT:-/opt/homebrew/bin/wp}

if [ -f "$LOCAL_HOME/sites.json" ] && command -v node >/dev/null 2>&1; then
  SITE_ID=$(
    node -e '
      const fs = require("node:fs");
      const os = require("node:os");
      const path = require("node:path");

      const sites = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
      const target = path.resolve(process.argv[2]);

      for (const [id, site] of Object.entries(sites)) {
        const sitePath = path.resolve(site.path.replace(/^~(?=\/|$)/, os.homedir()));

        if (sitePath === target) {
          process.stdout.write(id);
          process.exit(0);
        }
      }
    ' "$LOCAL_HOME/sites.json" "$SITE_BASE"
  )

  if [ -n "${SITE_ID:-}" ]; then
    PHP_VERSION=$(
      node -e '
        const fs = require("node:fs");
        const data = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
        const site = data[process.argv[2]];

        if (site?.services?.php?.version) {
          process.stdout.write(site.services.php.version);
        }
      ' "$LOCAL_HOME/sites.json" "$SITE_ID"
    )
    PHP_INI="$LOCAL_HOME/run/$SITE_ID/conf/php/php.ini"
    PHP_BIN=$(find "$LOCAL_HOME/lightning-services" -maxdepth 5 -path "*php-$PHP_VERSION+*/bin/darwin-arm64/bin/php" -type f | head -n 1)

    if [ -n "${PHP_BIN:-}" ] && [ -f "$PHP_INI" ]; then
      exec "$PHP_BIN" -c "$PHP_INI" "$WP_CLI_SCRIPT" --path="$SITE_ROOT" "$@"
    fi
  fi
fi

exec "$WP_CLI_SCRIPT" --path="$SITE_ROOT" "$@"
